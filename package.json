{
  "name": "operations-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Portfolio operations dashboard consuming live SLO and incident data",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
